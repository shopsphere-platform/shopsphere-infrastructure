# ══════════════════════════════════════════════════════════
# This Kubernetes Secret holds the connection details each
# Spring Boot service needs. In Helm (next phase), each
# service's deployment will reference these via:
#
#   envFrom:
#     - secretRef:
#         name: shopsphere-connections
#
# So application.yml just reads ${DB_HOST}, ${DB_PASSWORD},
# ${KAFKA_BOOTSTRAP_SERVERS}, ${REDIS_HOST} — same pattern as
# environment variable overrides in docker-compose.yml, just
# sourced from AWS instead of Docker.
# ══════════════════════════════════════════════════════════
apiVersion: v1
kind: Secret
metadata:
  name: shopsphere-connections
  namespace: shopsphere
type: Opaque
stringData:
  # ── Per-service Postgres hosts (from RDS module) ──────
  AUTH_DB_HOST: "{{ db_endpoints.auth }}"
  PRODUCTS_DB_HOST: "{{ db_endpoints.products }}"
  ORDERS_DB_HOST: "{{ db_endpoints.orders }}"
  PAYMENTS_DB_HOST: "{{ db_endpoints.payments }}"
  INVENTORY_DB_HOST: "{{ db_endpoints.inventory }}"
  NOTIFICATIONS_DB_HOST: "{{ db_endpoints.notifications }}"

  DB_USERNAME: "postgres"
  DB_PASSWORD: "{{ db_password }}"

  # ── Kafka (from MSK module) ───────────────────────────
  KAFKA_BOOTSTRAP_SERVERS: "{{ kafka_bootstrap_brokers }}"

  # ── Redis (from ElastiCache module) ───────────────────
  REDIS_HOST: "{{ redis_endpoint }}"
  REDIS_PORT: "6379"
